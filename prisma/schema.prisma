generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Porteiro {
  id       String   @id @default(uuid())
  nome     String   @unique
  criadoEm DateTime @default(now())
  acessos  Acesso[]
}

model Motorista {
  id       String   @id @default(uuid())
  cpf      String   @unique
  nome     String
  empresa  String
  criadoEm DateTime @default(now())
  acessos  Acesso[]
}

model Acesso {
  id              String    @id @default(uuid())
  dataEntrada     DateTime  @default(now())
  placa           String
  setor           String
  arquivoPdf      Bytes
  porteiroId      String
  motoristaId     String
  crachaDevolvido Boolean?
  numeroCracha    String?
  motorista       Motorista @relation(fields: [motoristaId], references: [id])
  porteiro        Porteiro  @relation(fields: [porteiroId], references: [id])

  @@index([motoristaId], map: "Acesso_motoristaId_fkey")
  @@index([porteiroId], map: "Acesso_porteiroId_fkey")
}
